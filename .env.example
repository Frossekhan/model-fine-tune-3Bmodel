# Enterprise AI Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model Configuration
MODEL_BASE=Qwen/Qwen2.5-3B-Instruct
LORA_OUTPUT_DIR=./models/lora-qwen3b-amazon-valid

# Embedding Model (for RAG)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHROMA_PERSIST_DIR=./chroma_store

# Database Configuration (Optional - app works without these)
REDIS_URL=redis://localhost:6379/0
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=enterprise_assistant
MONGODB_COLLECTION=conversations

# Sentiment Analysis
SENTIMENT_MODEL_PATH=./models/sentiment/naive_bayes.json
SENTIMENT_DATASET_PATH=./training/examples/sentiment_dataset.json
SENTIMENT_ALPHA=1.0

# Model Parameters
MAX_HISTORY=20
MAX_TOKENS=1024
MAX_NEW_TOKENS=512
TEMPERATURE=0.8
TOP_P=0.95

# Logging
LOG_LEVEL=INFO

# Features
ENABLE_STREAMING=true

# Optional: Hugging Face Token (for faster downloads)
# HF_TOKEN=your_token_here